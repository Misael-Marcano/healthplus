PORT=3001

# Base de datos SQL Server
DB_HOST=localhost
# Puerto: 1433 si tienes SQL Server instalado en Windows. Si usas solo `docker compose` de este repo,
# el servicio `sqlserver` publica el host en 1434 → usa DB_PORT=1434 (ver docker-compose.yml).
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=HealthPlus@2024!
DB_NAME=healthplus_db

# JWT
JWT_SECRET=healthplus_jwt_secret_change_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=healthplus_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d
# Duración del refresh token cuando el login envía remember=true (pantalla “Recuérdame”)
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d

# Frontend URL (CORS y enlaces en correos de recuperación de contraseña)
FRONTEND_URL=http://localhost:3000

# Si es true, ejecuta migraciones al arrancar la API (producción / Docker)
# RUN_MIGRATIONS_ON_BOOT=false

# Pruebas e2e: poner E2E_INTEGRATION=1 para ejecutar test/app.e2e-spec.ts contra SQL Server
# E2E_INTEGRATION=

# SMTP (opcional). Si defines SMTP_HOST, se usa antes que el SMTP guardado en Configuración del sistema.
# Útil en Docker/Kubernetes con secretos. Si no hay SMTP_HOST, se usa host/usuario/contraseña de system_settings (UI admin).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# Remitente From (opcional; por defecto email de organización en configuración)
# SMTP_FROM=ti@healthplus.com
# Solo si el servidor SMTP usa certificado no confiable (no recomendado en prod)
# SMTP_TLS_REJECT_UNAUTHORIZED=false
